<Window x:Class="ClaudeTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:behaviors="clr-namespace:ClaudeTimer.Behaviors"
        mc:Ignorable="d"
        Title="ClaudeTimer"
        Width="760"
        Height="570"
        MinWidth="680"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource CanvasBrush}"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#01FFFFFF" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center">
                <Border Width="24" Height="24" Background="{StaticResource AccentBrush}" CornerRadius="7">
                    <TextBlock Text="C"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="Bold" />
                </Border>
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Text="ClaudeTimer" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource IconButtonStyle}" Click="Minimize_Click" ToolTip="Minimér">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="10" Text="&#xE921;" />
                </Button>
                <Button Style="{StaticResource IconButtonStyle}" Click="Close_Click" ToolTip="Luk">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="10" Text="&#xE8BB;" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="32,20,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="*" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Text="Dit Claude-forbrug" />
                    <TextBlock Margin="1,7,0,0"
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="{Binding StatusText}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ShowTokenEditorCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Skift OAuth-token"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE72E;" />
                    </Button>
                    <Button Margin="4,0,0,0"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Opdatér nu"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE72C;" />
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="26"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.07" />
                    </Border.Effect>
                    <ContentControl Content="{Binding FiveHour}" ContentTemplate="{StaticResource UsageCardTemplate}" />
                </Border>

                <Border Grid.Column="2"
                        Padding="26"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.07" />
                    </Border.Effect>
                    <ContentControl Content="{Binding SevenDay}" ContentTemplate="{StaticResource UsageCardTemplate}" />
                </Border>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock FontSize="12"
                           Foreground="{StaticResource ErrorBrush}"
                           Text="{Binding ErrorText}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           FontSize="12"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding LastUpdatedText}" />
            </Grid>
        </Grid>

        <Border Grid.RowSpan="2"
                Margin="0"
                Background="#66000000"
                shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTokenEditorVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="480"
                    Padding="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="16">
                <StackPanel>
                    <Border Width="44"
                            Height="44"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="12">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="20"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="&#xE72E;" />
                    </Border>
                    <TextBlock Margin="0,18,0,0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Text="Forbind Claude" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               LineHeight="20"
                               TextWrapping="Wrap"
                               Text="Indsæt dit Claude Code OAuth-token. Det krypteres med Windows og kan kun læses af din bruger." />
                    <TextBlock Margin="0,20,0,7"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="OAUTH-TOKEN" />
                    <PasswordBox behaviors:PasswordBoxBinding.IsEnabled="True"
                                 behaviors:PasswordBoxBinding.BoundPassword="{Binding TokenInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PasswordChar="●" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource ErrorBrush}"
                               Text="{Binding ErrorText}" />
                    <StackPanel Margin="0,22,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Margin="0,0,8,0"
                                Command="{Binding CancelTokenEditorCommand}"
                                Content="Annullér"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Command="{Binding SaveTokenCommand}"
                                Content="Forbind"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                    <Button Margin="0,18,0,0"
                            HorizontalAlignment="Left"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ForgetTokenCommand}"
                            Foreground="{StaticResource MutedTextBrush}"
                            Content="Glem gemt token"
                            Cursor="Hand" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>

</Window>
